APP_NAME=WhatsAppBizAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Douala

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=whatsappbizai
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@whatsappbizai.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── WhatsApp Cloud API (Meta) ───────────────────────────────────────────────
# WHATSAPP_PHONE_NUMBER_ID et WHATSAPP_ACCESS_TOKEN sont configurés par chaque
# business dans son espace client. Seul le verify_token est global.
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here
WHATSAPP_API_VERSION=v20.0

# ─── Gemini API ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Flutterwave ─────────────────────────────────────────────────────────────
# Obtenez ces clés sur https://dashboard.flutterwave.com → Settings → API
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Activity Log ────────────────────────────────────────────────────────────
ACTIVITY_LOGGER_ENABLED=true

# ─── Installer ───────────────────────────────────────────────────────────────
APP_INSTALLED=false

# ─── Google OAuth (optionnel — connexion via Google) ─────────────────────────
# Créez un projet sur https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=${APP_URL}/auth/google/callback
